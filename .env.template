# ─────────────────────────────────────────
# AI Resume Matching System — Environment
# Copy this file to .env and fill in values
# NEVER commit .env to git
# ─────────────────────────────────────────

# ── OpenAI ─────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here

# ── Model Config ───────────────────────────
# Used for agents (skill, experience, technical, culture fit)
AGENT_MODEL=gpt-4o-mini

# Used for LLM-as-judge (culture fit scoring, explanation generation)
JUDGE_MODEL=gpt-4o

# Used for query understanding
QUERY_MODEL=gpt-4o-mini

# ── Embedding Config ───────────────────────
EMBEDDING_MODEL=text-embedding-3-small

# ── ChromaDB Config ────────────────────────
# Path where ChromaDB persists data locally
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION_NAME=resumes

# ── Retrieval Config ───────────────────────
# Number of candidates to retrieve before agent evaluation
TOP_K_RETRIEVAL=20

# Number of final ranked candidates to return
TOP_K_FINAL=5

# Hybrid search weights (must sum to 1.0)
VECTOR_SEARCH_WEIGHT=0.6
BM25_SEARCH_WEIGHT=0.4

# ── API Config ─────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
