%% ============================================================
subgraph A["A · Data Ingestion (offline / one-time)"]
  direction LR
  A1["📄 Resume Sources\nResume.csv\nPDFs (24 categories)"]
  A2["🔧 Parser & Cleaner\ningestion/parser.py\nPDF extraction (PyMuPDF)\nCSV row parsing\nHTML/URL removal"]
  A3["✂️ Chunker\ningestion/chunker.py\n500-char chunks, 50 overlap\nSection-aware splitting\n→ chunks_cache.pkl"]
  A1 --> A2 --> A3
end

%% ============================================================
%% B · Embedding & Indexing
%% ============================================================
subgraph B["B · Embedding & Indexing"]
  direction LR
  B1["🧠 Embedder\ningestion/embedder.py\ntext-embedding-3-small\n1536-dim vectors\n→ ChromaDB (cosine, SQLite)"]
  B2["🔑 BM25 Index\nretrieval/keyword_search.py\nBM25Okapi algorithm\nBuilt on first use\n→ bm25_index.pkl"]
  B3["📝 Resume Summarizer\ningestion/summarizer.py\nGPT-4o-mini structured digest\nSKILLS/EXP/EDU/PROJECTS/CERTS\n→ resume_summaries_cache.pkl\nLLM called once per resume"]
end
A3 --> B1
A3 --> B2
A3 --> B3

%% ============================================================
%% C · Hybrid Retrieval  (per query)
%% ============================================================
subgraph C["C · Hybrid Retrieval (per query)"]
  direction LR
  C0["🔍 LLM Query Expansion\ngpt-4o-mini\nExpands query with\nrelated keywords"]
  C1["📊 ChromaDB\nSemantic Search\nweight = 0.6"]
  C2["📊 BM25\nKeyword Search\nweight = 0.4"]
  C3["🔀 RRF Fusion\nReciprocal Rank Fusion\nk = 60\nDeduplicate by resume_id"]
  C4["📐 Cross-Encoder Reranking\nms-marco-MiniLM-L-6-v2\nReranks RRF results\nFallback: heuristic scorer"]
  C0 --> C1
  C0 --> C2
  C1 --> C3
  C2 --> C3
  C3 --> C4
end

%% ============================================================
%% D · LangGraph 6-Node Pipeline
%% ============================================================
subgraph D["D · LangGraph Evaluation Pipeline (6 nodes)"]
  direction LR
  D1["① retrieve_candidates\nHybrid search\n(calls Lane C)"]
  D2["② parse_candidates\nResume Parsing Agent\nHeuristic · zero LLM cost\nSection detection (8 types)\nbias_flags attached"]
  D3["③ enrich_candidates\nAssemble full resume text\nAll chunks via closure\nUp to 3000 chars/candidate"]
  D4["④ summarize_candidates\nGPT-4o-mini per resume\nStructured digest\nDisk cache R/W"]
  D5["⑤ evaluate_candidates\n4 specialist agents\n(see Lane E)"]
  D6["⑥ aggregate_scores\nDynamic weight profile\nskill 0.40 / exp 0.25\ntech 0.20 / culture 0.15\n+ NL explanation"]
  D1 --> D2 --> D3 --> D4 --> D5 --> D6
end
C3 --> D1

%% ============================================================
