%% ============================================================
subgraph E["E · 5 Specialist Agents (Nodes ② & ⑤)"]
  direction LR
  E1["🤖 Resume Parsing\nHeuristic · zero LLM\nSection detection\n+ bias flags\n(runs at Node ②)"]
  E2["🤖 Skill Matching\ngpt-4o-mini\nSkill coverage\nmatched/missing/partial"]
  E3["🤖 Experience\ngpt-4o-mini\nYears & seniority\nCareer progression"]
  E4["🤖 Technical Depth\ngpt-4o-mini\nProject complexity\nTech stack extraction"]
